# ─────────────────────────────────────────────────────────────────────────────
# Supabase — required
# Dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
# Server-only. NEVER expose in the browser or commit to git.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ─────────────────────────────────────────────────────────────────────────────
# Stripe — required for payments
# Dashboard → Developers → API keys
# ─────────────────────────────────────────────────────────────────────────────
# Server-only secret key. NEVER expose in the browser.
STRIPE_SECRET_KEY=sk_test_<your-secret-key>
# Webhook signing secret — from `stripe listen` or Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-secret>
# Price ID for the monthly hub membership (Dashboard → Products → copy price ID)
STRIPE_PRICE_HUB_MONTHLY=price_<your-price-id>

# ─────────────────────────────────────────────────────────────────────────────
# Resend — required for email
# https://resend.com/api-keys
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_<your-key>
EMAIL_FROM=noreply@yourdomain.com
# Optional: coach email to receive new lead notifications
COACH_EMAIL=coach@yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
